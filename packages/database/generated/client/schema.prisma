generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(cuid())
  appleSub String  @unique
  email    String?

  // RevenueCat subscription
  rcCustomerId   String?   @unique // equals user.id by convention
  isPro          Boolean   @default(false)
  proExpiresAt   DateTime?
  proActivatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens            RefreshToken[]
  privateTrainingTemplates TrainingTemplate[]     @relation("UserPrivateTrainingTemplates")
  trainingRuns             TrainingRun[]
  achievements             UserAchievement[]
  progressCache            TrainingProgressCache?
  diveRuns                 DiveRun[]
}

model RefreshToken {
  id        String @id @default(cuid())
  userId    String
  tokenHash String @unique

  deviceId String?

  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, deviceId])
}

enum Language {
  en
  ru
}

enum CultureSection {
  STORIES
  ATHLETES
  COMPETITIONS
  TRAINING
  RELAX
  SAFETY
}

model CultureArticle {
  id              String         @id @default(cuid())
  slug            String         @unique
  section         CultureSection
  coverImageUrl   String?
  readTimeMinutes Int?
  publishedAt     DateTime?
  isPublished     Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations CultureArticleTranslation[]
  tags         CultureTagOnArticle[]

  @@index([section, isPublished, publishedAt])
}

model CultureArticleTranslation {
  id        String   @id @default(cuid())
  articleId String
  lang      Language

  title           String
  subtitle        String?
  description     String?
  contentMarkdown String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article CultureArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, lang])
  @@index([lang])
}

model CultureTag {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  articles CultureTagOnArticle[]
}

model CultureTagOnArticle {
  articleId String
  tagId     String

  article CultureArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     CultureTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
}

enum TrainingProgramKey {
  BEGINNER
  INTERMEDIATE
  PRO
  SQUARE
  CALMING
  DYNAMIC
  STATIC
  WARM_UP
}

enum TrainingKind {
  PRESET
  PRIVATE
}

enum BreathPhase {
  INHALE
  HOLD
  EXHALE
  REST
}

model TrainingProgram {
  id          String             @id @default(cuid())
  key         TrainingProgramKey @unique
  slug        String             @unique
  sortOrder   Int                @default(0)
  isPublished Boolean            @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations TrainingProgramTranslation[]
  trainings    TrainingTemplate[]

  @@index([sortOrder, isPublished])
}

model TrainingProgramTranslation {
  id        String   @id @default(cuid())
  programId String
  lang      Language

  title       String
  description String?

  program TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, lang])
  @@index([lang])
}

model TrainingTemplate {
  id   String       @id @default(cuid())
  kind TrainingKind @default(PRESET)

  slug      String? @unique
  programId String?

  ownerId String?
  name    String?

  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)
  isPremium   Boolean @default(false)

  pointCount  Int?
  repeats     Int?
  saveResults Boolean @default(true)
  saveCO2     Boolean @default(false)
  onlyClock   Boolean @default(false)

  estimatedMinutes Int?
  intensityLevel   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  program TrainingProgram? @relation(fields: [programId], references: [id], onDelete: SetNull)

  owner User? @relation("UserPrivateTrainingTemplates", fields: [ownerId], references: [id], onDelete: Cascade)

  translations TrainingTemplateTranslation[]
  steps        TrainingStep[]
  runs         TrainingRun[]

  @@index([programId, sortOrder])
  @@index([ownerId, kind])
}

model TrainingTemplateTranslation {
  id         String   @id @default(cuid())
  templateId String
  lang       Language

  title       String
  subtitle    String?
  description String?

  template TrainingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, lang])
  @@index([lang])
}

model TrainingStep {
  id         String @id @default(cuid())
  templateId String
  sortOrder  Int

  phase           BreathPhase
  durationSeconds Int

  template TrainingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model TrainingRun {
  id         String @id @default(cuid())
  userId     String
  templateId String

  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  totalSeconds Int?
  completed    Boolean   @default(false)

  metrics Json?

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  template TrainingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([templateId])
}

enum AchievementType {
  FIRST_TRAINING
  FIRST_PRIVATE

  STREAK_3
  STREAK_7
  STREAK_30

  TOTAL_RUNS_25
  TOTAL_RUNS_50
  TOTAL_RUNS_100

  COMPLETE_MAIN_12
}

model UserAchievement {
  id         String          @id @default(cuid())
  userId     String
  type       AchievementType
  scopeKey   String          @default("GLOBAL")
  unlockedAt DateTime        @default(now())
  payload    Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, scopeKey])
  @@index([userId, unlockedAt])
}

model TrainingProgressCache {
  userId    String   @id
  updatedAt DateTime @updatedAt
  data      Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum DiveDifficulty {
  EASY
  MEDIUM
  HARD
}

model DiveTemplate {
  id          String  @id @default(cuid())
  slug        String  @unique
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)
  isPremium   Boolean @default(false)

  difficulty        DiveDifficulty @default(EASY)
  maxDepthMeters    Int
  targetHoldSeconds Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations  DiveTemplateTranslation[]
  profilePoints DiveProfilePoint[]
  runs          DiveRun[]

  @@index([sortOrder, isPublished])
  @@index([isPremium, difficulty])
}

model DiveTemplateTranslation {
  id         String   @id @default(cuid())
  templateId String
  lang       Language

  title       String
  subtitle    String?
  description String?

  template DiveTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, lang])
  @@index([lang])
}

model DiveProfilePoint {
  id         String @id @default(cuid())
  templateId String
  sortOrder  Int

  timeSeconds Int
  depthMeters Int

  template DiveTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model DiveRun {
  id         String @id @default(cuid())
  userId     String
  templateId String

  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  holdSeconds    Int?
  maxDepthMeters Int?
  completed      Boolean   @default(false)

  metrics Json?

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  template DiveTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
  @@index([templateId])
}
